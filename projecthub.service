[Unit]
Description=ProjectHub - personal project manager (FastAPI + OpenClaw review)
After=network.target openclaw-gateway.service
Wants=openclaw-gateway.service

[Service]
Type=simple
User=rendra
WorkingDirectory=/home/rendra/projecthub
Environment=HOME=/home/rendra
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/local/bin/uvicorn app:app --host 0.0.0.0 --port 5055
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
